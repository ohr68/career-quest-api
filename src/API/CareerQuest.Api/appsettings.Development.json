{
  "ConnectionStrings": {
    "Database": "Host=career.quest.database;Port=5432;Database=career.quest;Username=postgres;Password=postgres;Include Error Detail=true",
    "Cache": "career.quest.redis:6379"
  },
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [
        "http://career.quest.identity:8080/realms/career.quest",
        "http://localhost:18080/realms/career.quest"
      ]
    },
    "MetadataAddress": "http://career.quest.identity:8080/realms/career.quest/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://career.quest.identity:9000/health"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://career.quest.seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "career.quest.Api"
    }
  }
}
